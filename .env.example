# Cyberbase Environment Variables
# Copy this file to .env and fill in actual values
# NEVER commit .env to git

# GitHub OAuth (for Decap CMS)
# Create OAuth App at: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Site URL (used for OAuth callbacks)
SITE_URL=http://localhost:4321

# Cloudflare Pages Deployment
# These go in GitHub Secrets (Settings > Secrets > Actions), NOT in .env
# Get Account ID: https://dash.cloudflare.com/ → any domain → Overview → right sidebar
# Create API Token: https://dash.cloudflare.com/profile/api-tokens
#   → Create Token → Edit Cloudflare Workers (or custom with Pages permissions)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
